{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@config/*": ["packages/config/src/*"],
      "@database/*": ["packages/database/src/*"],
      "@types/*": ["packages/types/src/*"]
    }
  }
}